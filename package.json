{
  "name": "@xanui/ui",
  "version": "1.2.20",
  "description": "A modern, fully-typed React UI component library — 60+ components, an OKLCH-based theming engine via createTheme(), responsive props, and a flexible Tag primitive system. Built on @xanui/core",
  "private": false,
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "scripts": {
    "start": "makepack start",
    "build": "makepack build",
    "release": "makepack release"
  },
  "dependencies": {
    "@xanui/core": "^1.3.31",
    "@xanui/icons": "^1.1.14",
    "pretty-class": "^1.0.8"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "makepack": "^1.7.27",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-state-bucket": "^1.2.18",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs",
      "types": "./index.d.ts"
    },
    "./*": {
      "import": "./*/index.js",
      "require": "./*/index.cjs",
      "types": "./*/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "*/index.d.ts"
      ]
    }
  },
  "keywords": [
    "react",
    "ui",
    "ui-library",
    "component-library",
    "react-components",
    "design-system",
    "typescript",
    "theming",
    "oklch",
    "responsive",
    "tailwind-alternative",
    "headless-ui",
    "frontend",
    "nextjs"
  ]
}
